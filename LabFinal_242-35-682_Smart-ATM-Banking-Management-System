import java.util.*;

class Transaction {
    private String type;
    private double amount;
    private double balanceAfter;

    public Transaction(String type, double amount, double balanceAfter) {
        this.type = type;
        this.amount = amount;
        this.balanceAfter = balanceAfter;
    }

    @Override
    public String toString() {
        return type + " | Amount: $" + amount + " | Balance: $" + balanceAfter;
    }
}

abstract class BankAccount {
    
    private String accountHolderName;
    private String accountNumber;
    private int pinCode;
    private double currentBalance;
    
    protected List<Transaction> history = new ArrayList<>();

    public BankAccount(String name, double initialBalance, int pin) {
        this.accountHolderName = name;
        this.currentBalance = initialBalance;
        this.pinCode = pin;
        this.accountNumber = "AC-" + (10000 + new Random().nextInt(90000));
        addTransaction("Account Created", initialBalance);
    }

    public String getAccountNumber() { return accountNumber; }
    public String getName() { return accountHolderName; }
    public double getBalance() { return currentBalance; }

    public boolean verifyPin(int inputPin) {
        return this.pinCode == inputPin;
    }

    protected void setBalance(double balance) {
        this.currentBalance = balance;
    }

    protected void addTransaction(String type, double amount) {
        history.add(new Transaction(type, amount, currentBalance));
    }

    public void deposit(double amount) {
        if (amount > 0) {
            currentBalance += amount;
            addTransaction("Deposit", amount);
            System.out.println("Deposited: $" + amount + " | New Balance: $" + currentBalance);
        } else {
            System.out.println("Invalid amount!");
        }
    }

    public void withdraw(double amount) {
        if (amount > 0 && currentBalance >= amount) {
            currentBalance -= amount;
            addTransaction("Withdraw", amount);
            System.out.println("Withdrawn: $" + amount + " | New Balance: $" + currentBalance);
        } else {
            System.out.println("Insufficient Balance or Invalid Amount!");
        }
    }

    public void showHistory() {
        System.out.println("\n--- Transaction History ---");
        for (Transaction t : history) {
            System.out.println(t);
        }
    }

    abstract void applyInterest();
}

class SavingsAccount extends BankAccount {

    public SavingsAccount(String name, double balance, int pin) {
        super(name, balance, pin);
    }

    @Override
    void applyInterest() {
        double interest = getBalance() * 0.05; 
        setBalance(getBalance() + interest);
        addTransaction("Interest Added (5%)", interest);
        System.out.println("5% Interest Applied. Earned: $" + interest);
    }
}

class CurrentAccount extends BankAccount {

    public CurrentAccount(String name, double balance, int pin) {
        super(name, balance, pin);
    }

    @Override
    void applyInterest() {
        System.out.println("No Interest is applicable for Current Accounts.");
    }
}

class ATM {
    private List<BankAccount> accountsDB = new ArrayList<>();
    private Scanner scanner = new Scanner(System.in);

    public void start() {
        System.out.println("Welcome to Smart ATM System");
        while (true) {
            System.out.println("\n1. Create Account | 2. Login | 3. Exit");
            System.out.print("Option: ");
            int choice = scanner.nextInt();

            if (choice == 1) createAccount();
            else if (choice == 2) login();
            else break;
        }
    }

    private void createAccount() {
        scanner.nextLine(); 
        System.out.print("Name: ");
        String name = scanner.nextLine();
        System.out.print("Initial Deposit: ");
        double balance = scanner.nextDouble();
        System.out.print("Set 4-digit PIN: ");
        int pin = scanner.nextInt();
        System.out.print("Type (1. Savings, 2. Current): ");
        int type = scanner.nextInt();

        BankAccount newAccount = (type == 1) ? new SavingsAccount(name, balance, pin) : new CurrentAccount(name, balance, pin);
        accountsDB.add(newAccount);
        System.out.println("\nAccount Created! Account No: " + newAccount.getAccountNumber());
    }

    private void login() {
        System.out.print("Account No: ");
        String accNo = scanner.next();
        
        BankAccount userAcc = null;
        for (BankAccount acc : accountsDB) {
            if (acc.getAccountNumber().equals(accNo)) {
                userAcc = acc; break;
            }
        }

        if (userAcc == null) { System.out.println("Account not found!"); return; }

        System.out.print("PIN: ");
        if (userAcc.verifyPin(scanner.nextInt())) {
            dashboard(userAcc);
        } else {
            System.out.println("Wrong PIN!");
        }
    }

    private void dashboard(BankAccount acc) {
        while (true) {
            System.out.println("\n--- Dashboard (" + acc.getName() + ") ---");
            System.out.println("1. Deposit | 2. Withdraw | 3. Balance | 4. Interest | 5. History | 6. Logout");
            System.out.print("Choice: ");
            switch (scanner.nextInt()) {
                case 1: System.out.print("Amount: "); acc.deposit(scanner.nextDouble()); break;
                case 2: System.out.print("Amount: "); acc.withdraw(scanner.nextDouble()); break;
                case 3: System.out.println("Balance: $" + acc.getBalance()); break;
                case 4: acc.applyInterest(); break;
                case 5: acc.showHistory(); break;
                case 6: return;
                default: System.out.println("Invalid!");
            }
        }
    }
}

public class SmartATMSystem {
    public static void main(String[] args) {
        new ATM().start();
    }
}
